# Copy this file to .env and fill in your values.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# PostgreSQL — required. The project does NOT support SQLite.
DB_NAME=umlab_db
DB_USER=umlab_user
